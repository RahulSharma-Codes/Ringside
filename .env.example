# ─────────────────────────────────────────────────────────────────────────────
# Ringside — Required Environment Variables
# Copy this file to .env.local (never commit .env files — they are gitignored)
# Set these in Replit Secrets for production deployments.
# ─────────────────────────────────────────────────────────────────────────────

# JWT signing secret — MUST be at least 32 characters of random data.
# Generate with: openssl rand -hex 32
SESSION_SECRET=replace-with-at-least-32-chars-of-random-data

# OpenAI API key for the AI Copilot feature
OPENAI_API_KEY=sk-...

# Replit Object Storage bucket ID (visible in the Replit .replit file)
DEFAULT_OBJECT_STORAGE_BUCKET_ID=replit-objstore-...

# ── First-run production bootstrap ────────────────────────────────────────────
# Set both of these on first deploy to create the initial admin account.
# Leave unset after the first boot — the seed logic only runs when the
# users table is empty.
BOOTSTRAP_ADMIN_EMAIL=admin@yourdomain.com
BOOTSTRAP_ADMIN_PASSWORD=replace-with-strong-password

# ── Playwright / E2E test credentials ────────────────────────────────────────
# Used by the test suite to log in. Falls back to dev seed values when not set.
TEST_EMAIL=admin@yourdomain.com
TEST_PASSWORD=replace-with-test-password

# ── SMTP (optional — required for OTP login flow in production) ───────────────
SMTP_HOST=smtp.yourmailprovider.com
SMTP_PORT=587
SMTP_USER=noreply@yourdomain.com
SMTP_PASS=replace-with-smtp-password
SMTP_FROM=Ringside <noreply@yourdomain.com>

# ── Error monitoring (optional) ───────────────────────────────────────────────
# Sentry DSN for capturing unhandled exceptions, migration failures, and backup
# errors. When not set, the server and backup worker start normally — Sentry is
# fully optional. Get your DSN from https://sentry.io → Project Settings → DSN.
SENTRY_DSN=

# ── PostgreSQL connection (auto-set by Replit; required when running outside Replit) ──
# Replit Postgres sets these automatically. When running locally (e.g. Docker Compose)
# point them at your local Postgres instance.
PGHOST=localhost
PGPORT=5432
PGUSER=postgres
PGPASSWORD=replace-with-db-password
PGDATABASE=ringside
